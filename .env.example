# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Django secret key — signs sessions and magic-link tokens. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# Required in production; without it the app falls back to an insecure dev key.
SECRET_KEY=

# Email SMTP credentials (used to send magic-link sign-in emails)
EMAIL_USE_TLS=True
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=FlexTime <you@gmail.com>

# Base URL used to build absolute magic links in emails
SITE_URL=http://127.0.0.1:8000
